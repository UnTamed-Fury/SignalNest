#!/bin/sh
# Gradle wrapper script for Termux

APP_HOME=$(cd "$(dirname "$0")" && pwd -P)
GRADLE_WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

# Termux-friendly JVM args
GRADLE_OPTS="-Xmx1024m -XX:MaxMetaspaceSize=256m -Dorg.gradle.daemon=false -Dorg.gradle.workers.max=1"

exec java $GRADLE_OPTS -jar "$GRADLE_WRAPPER_JAR" -p "$APP_HOME" "$@"
